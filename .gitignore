# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# planning docs — never shipped in a commit
plans/

# rebuild rollback safety — pre-rebuild snapshot
_archive/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

prompt.md

scripts/create-admin.js

# Claude Code editor settings — local-only
.claude/
