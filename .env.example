# ECS Specialization Course Landing Page — env var reference
#
# Copy this file to .env.local and fill in values. Never commit .env.local.
# Every var listed here must be read through lib/env.ts (Zod-validated) and
# imported by scripts/validate-env.ts so that missing values fail the build,
# not the runtime. See plans/00-descriptions.md §3 Security.

# --- MongoDB ---
# Full connection string, including database name.
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/ecs-specialization

# --- NextAuth (admin surface at /admin) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Production: https://ecs-specialization.betterbud.club. Local dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# --- reCAPTCHA v3 (public lead form bot check) ---
# Site key is client-visible; secret is server-only. Turnstile migration is tracked
# in the witus user-task queue (02-cloudflare-turnstile-setup.md).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Outbound lead webhook → witus-inbox (v1b) ---
# Target URL for HMAC-signed lead POSTs. Leave blank in preview to trigger the
# dev-log fallback per plans/00-descriptions.md §3 Security.
INGEST_TARGET_URL=
# Shared HMAC secret (must match witus-inbox INGEST_SOURCES seed for this source).
# Source slug used in the payload: "betterbud-ecs".
INGEST_HMAC_SECRET=
