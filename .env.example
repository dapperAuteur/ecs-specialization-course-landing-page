# ECS Specialization: env var reference
#
# Copy to .env.local and fill in values. Never commit .env.local.
# All vars are read through lib/env.ts (Zod-validated, lazy) and verified at
# build by scripts/validate-env.ts. Operator-side provisioning is tracked in
# witus/plans/user-tasks/21-fdac-ecs-rebuild-secret-provisioning.md.

# --- Neon Postgres (per task #21 §C) ---
# Pooled URL for runtime queries; unpooled for drizzle-kit migrations.
STORAGE_DATABASE_URL=postgres://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/ecs-leads?sslmode=require
STORAGE_DATABASE_URL_UNPOOLED=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/ecs-leads?sslmode=require

# --- Google reCAPTCHA v3 (Q5 lock 2026-05-04) ---
# Public site key visible client-side; secret key server-only.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Inbox webhook (per task #21 §D/E) ---
# Production: https://inbox.witus.online/api/ingest
# Local dev:  http://localhost:3000/api/ingest (witus-inbox repo)
INBOX_INGEST_URL=https://inbox.witus.online/api/ingest
# 32+ char shared secret. Mirror the value in witus-inbox's INGEST_SOURCES JSON
# under {"slug": "betterbud-ecs", "hmac_secret": "<this value>"}.
INBOX_INGEST_SECRET=
INBOX_SOURCE_SLUG=betterbud-ecs

# --- Ebook delivery (Phase 8) ---
# 32+ char HMAC key for signing 24h JWT download URLs. Generate with:
#   openssl rand -hex 32
EBOOK_JWT_SECRET=
# Used to substitute the download URL into Keap email merge fields once
# Keap integration ships (currently backlog; see plans/future/keap-integration.md).
# Production: https://ecs-specialization.betterbud.club
# Local dev:  http://localhost:3000
EBOOK_BASE_URL=http://localhost:3000

# --- Age-gate (Phase 9; per task #21 §E) ---
# 32+ char HMAC key for signing the 21+ attestation cookie.
AGE_GATE_COOKIE_SECRET=
